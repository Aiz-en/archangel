# Copy this file to .env and fill in your real values.
# .env is gitignored; .env.example is the committed template.

# --- Official Webull OpenAPI (live order execution, future) ---
# Generate at https://developer.webull.com/ after API access is approved.
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_REGION=us

# --- Unofficial Webull paper trading (current paper-trading phase) ---
# These are the username + password of an ISOLATED Webull account
# created specifically for the bot. Do NOT use your personal Webull
# account credentials. The account should have NO funded live side.
# See code_base/webull_paper.py docstring for the full security model.
WEBULL_PAPER_USERNAME=
WEBULL_PAPER_PASSWORD=
